Subject: EasyForm — a few details still needed
<!DOCTYPE html>
<html><head><meta charset="UTF-8"></head>
<body style="margin:0;padding:24px 12px;background:#f1f5f9;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Arial,sans-serif;color:#0f172a">
<table cellpadding="0" cellspacing="0" border="0" style="max-width:640px;margin:0 auto;width:100%;background:#fff;border-radius:14px;overflow:hidden;box-shadow:0 4px 24px -8px rgba(15,23,42,0.15)">
  <tr><td style="background:linear-gradient(135deg,#4f46e5,#9333ea);padding:22px 28px;color:#fff">
    <h1 style="margin:0;font-size:21px">EasyForm</h1>
    <p style="margin:6px 0 0;font-size:14px;opacity:0.92">A few details are missing for your application</p>
  </td></tr>
  <tr><td style="padding:24px 28px">
    <p>Hi <strong>{{ candidate_name or "there" }}</strong>,</p>
    <p>Thanks for sending your documents to EasyForm. We've made progress but couldn't finish the form because of the items below. Please reply with the missing information so we can complete it for you.</p>

    {% if cats.docs %}
    <h2 style="font-size:13px;font-weight:700;color:#dc2626;letter-spacing:0.06em;text-transform:uppercase;margin:22px 0 8px">📎 Documents we still need</h2>
    <table cellpadding="0" cellspacing="0" border="0" style="width:100%;border-collapse:collapse;background:#fef2f2;border:1px solid #fecaca;border-radius:8px">
      {% for d in cats.docs %}
      <tr><td style="padding:10px 14px;font-size:14px;{% if not loop.last %}border-bottom:1px solid #fecaca;{% endif %}">• {{ d }}</td></tr>
      {% endfor %}
    </table>
    <p style="font-size:13px;color:#64748b;margin:8px 2px">Please attach these to your reply.</p>
    {% endif %}

    {% if cats.gaps %}
    <h2 style="font-size:13px;font-weight:700;color:#d97706;letter-spacing:0.06em;text-transform:uppercase;margin:22px 0 8px">🔍 Details we couldn't read from your documents</h2>
    <table cellpadding="0" cellspacing="0" border="0" style="width:100%;border-collapse:collapse;background:#fffbeb;border:1px solid #fde68a;border-radius:8px">
      {% for g in cats.gaps %}
      <tr><td style="padding:10px 14px;font-size:14px;{% if not loop.last %}border-bottom:1px solid #fde68a;{% endif %}">
        We received your <strong>{{ g.doc }}</strong> but couldn't extract the <strong>{{ g.field }}</strong>.
      </td></tr>
      {% endfor %}
    </table>
    <p style="font-size:13px;color:#64748b;margin:8px 2px">Send a clearer scan, <strong>or</strong> just reply with the value in plain English (e.g. "my 12th stream was Science").</p>
    {% endif %}

    {% if cats.personal %}
    <h2 style="font-size:13px;font-weight:700;color:#4f46e5;letter-spacing:0.06em;text-transform:uppercase;margin:22px 0 8px">👤 Personal details we don't have</h2>
    <table cellpadding="0" cellspacing="0" border="0" style="width:100%;border-collapse:collapse;background:#eef2ff;border:1px solid #c7d2fe;border-radius:8px">
      {% for f in cats.personal %}
      <tr><td style="padding:10px 14px;font-size:14px;{% if not loop.last %}border-bottom:1px solid #c7d2fe;{% endif %}">• {{ f.label }}</td></tr>
      {% endfor %}
    </table>
    <p style="font-size:13px;color:#64748b;margin:8px 2px">Just reply naturally — e.g. "I am single, Indian, OBC. My mobile is 9876543210."</p>
    {% endif %}

    {% if validation_errors %}
    <h2 style="font-size:13px;font-weight:700;color:#dc2626;letter-spacing:0.06em;text-transform:uppercase;margin:22px 0 8px">⛔ Issues with the documents you sent</h2>
    <table cellpadding="0" cellspacing="0" border="0" style="width:100%;border-collapse:collapse;background:#fef2f2;border:1px solid #fecaca;border-radius:8px">
      {% for e in validation_errors %}
      <tr><td style="padding:10px 14px;font-size:13.5px;{% if not loop.last %}border-bottom:1px solid #fecaca;{% endif %}"><code style="font-size:11.5px;background:#fff;padding:1px 5px;border-radius:3px">{{ e.code }}</code> &nbsp; {{ e.detail }}</td></tr>
      {% endfor %}
    </table>
    {% endif %}

    <div style="margin-top:24px;padding:14px 16px;background:#f1f5f9;border-radius:10px;color:#334155;font-size:13.5px">
      Please reply within <strong>6 hours</strong>. We'll send one reminder if we don't hear back.
    </div>

    <p style="margin-top:18px;font-size:12px;color:#94a3b8">Reference ID: {{ user_id }}</p>
    <p style="margin:4px 0 0;font-size:12px;color:#94a3b8">— EasyForm</p>
  </td></tr>
</table>
</body></html>
