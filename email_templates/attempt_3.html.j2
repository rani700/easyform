Subject: EasyForm — final reminder: your application will be cancelled
<!DOCTYPE html>
<html><head><meta charset="UTF-8"></head>
<body style="margin:0;padding:24px 12px;background:#f1f5f9;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Arial,sans-serif;color:#0f172a">
<table cellpadding="0" cellspacing="0" border="0" style="max-width:640px;margin:0 auto;width:100%;background:#fff;border-radius:14px;overflow:hidden;box-shadow:0 4px 24px -8px rgba(15,23,42,0.15)">
  <tr><td style="background:#dc2626;padding:22px 28px;color:#fff">
    <h1 style="margin:0;font-size:21px">⛔ EasyForm — final reminder</h1>
    <p style="margin:6px 0 0;font-size:14px;opacity:0.92">Your application will be cancelled if we don't hear back</p>
  </td></tr>
  <tr><td style="padding:24px 28px">
    <p>Hi <strong>{{ candidate_name or "there" }}</strong>,</p>
    <p>This is the final reminder. We've reached out twice for the items below and haven't heard back. If we don't receive a reply within the next 6 hours, your application will be <strong>cancelled</strong> and the partial data we hold will be discarded.</p>

    {% if cats.docs %}
    <h2 style="font-size:13px;font-weight:700;color:#dc2626;letter-spacing:0.06em;text-transform:uppercase;margin:22px 0 8px">Documents we still need</h2>
    <table cellpadding="0" cellspacing="0" border="0" style="width:100%;border-collapse:collapse;background:#fef2f2;border:1px solid #fecaca;border-radius:8px">
      {% for d in cats.docs %}<tr><td style="padding:10px 14px;font-size:14px;{% if not loop.last %}border-bottom:1px solid #fecaca;{% endif %}">• {{ d }}</td></tr>{% endfor %}
    </table>
    {% endif %}

    {% if cats.gaps %}
    <h2 style="font-size:13px;font-weight:700;color:#d97706;letter-spacing:0.06em;text-transform:uppercase;margin:22px 0 8px">Details we couldn't read</h2>
    <table cellpadding="0" cellspacing="0" border="0" style="width:100%;border-collapse:collapse;background:#fffbeb;border:1px solid #fde68a;border-radius:8px">
      {% for g in cats.gaps %}<tr><td style="padding:10px 14px;font-size:14px;{% if not loop.last %}border-bottom:1px solid #fde68a;{% endif %}">{{ g.doc }} — <strong>{{ g.field }}</strong></td></tr>{% endfor %}
    </table>
    {% endif %}

    {% if cats.personal %}
    <h2 style="font-size:13px;font-weight:700;color:#4f46e5;letter-spacing:0.06em;text-transform:uppercase;margin:22px 0 8px">Personal details</h2>
    <table cellpadding="0" cellspacing="0" border="0" style="width:100%;border-collapse:collapse;background:#eef2ff;border:1px solid #c7d2fe;border-radius:8px">
      {% for f in cats.personal %}<tr><td style="padding:10px 14px;font-size:14px;{% if not loop.last %}border-bottom:1px solid #c7d2fe;{% endif %}">• {{ f.label }}</td></tr>{% endfor %}
    </table>
    {% endif %}

    <p style="margin-top:18px;font-size:12px;color:#94a3b8">Reference ID: {{ user_id }} &nbsp;·&nbsp; — EasyForm</p>
  </td></tr>
</table>
</body></html>
