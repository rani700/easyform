Subject: EasyForm — please review and confirm your details
{# Reset macro for null-safe display #}
{% macro v(x) %}{{ x if x not in (None, '', false) else '—' }}{% endmacro %}
{% macro yn(x) %}{% if x %}<span style="color:#16a34a;font-weight:600">✓ valid</span>{% else %}<span style="color:#dc2626;font-weight:600">— missing</span>{% endif %}{% endmacro %}
{% macro present(x) %}{% if x %}<span style="color:#16a34a;font-weight:600">✓ received</span>{% else %}<span style="color:#94a3b8">— not received</span>{% endif %}{% endmacro %}
{% macro pretty_mode(s) -%}
{%- if s == 'full_time' -%}Full-Time
{%- elif s == 'part_time' -%}Part-Time
{%- elif s == 'distance' -%}Distance
{%- elif s == 'unknown' or not s -%}—
{%- else -%}{{ s|replace('_', ' ')|title }}
{%- endif -%}
{% endmacro %}
{% macro period(rec) -%}
{%- if rec.year_of_passing and rec.course_duration_years -%}
{{ (rec.year_of_passing|int) - (rec.course_duration_years|int) }} – {{ rec.year_of_passing }}
{%- elif rec.year_of_passing -%}{{ rec.year_of_passing }}
{%- else -%}—
{%- endif -%}
{% endmacro %}
{% macro edu_table(rec, show_spec=true, show_period=true) %}
  {% if rec %}
  <table cellpadding="0" cellspacing="0" border="0" style="width:100%;border-collapse:collapse;margin-top:6px">
    <tr><td style="padding:6px 10px;background:#f8fafc;width:42%;color:#64748b;font-size:13px;border-bottom:1px solid #e2e8f0">Institute</td><td style="padding:6px 10px;font-size:14px;border-bottom:1px solid #e2e8f0">{{ v(rec.institute_name) }}</td></tr>
    <tr><td style="padding:6px 10px;background:#f8fafc;color:#64748b;font-size:13px;border-bottom:1px solid #e2e8f0">Board / University</td><td style="padding:6px 10px;font-size:14px;border-bottom:1px solid #e2e8f0">{{ v(rec.board_or_university) }}</td></tr>
    {% if show_period and rec.year_of_passing and rec.course_duration_years %}<tr><td style="padding:6px 10px;background:#f8fafc;color:#64748b;font-size:13px;border-bottom:1px solid #e2e8f0">Course Period</td><td style="padding:6px 10px;font-size:14px;border-bottom:1px solid #e2e8f0">{{ period(rec) }}</td></tr>{% endif %}
    <tr><td style="padding:6px 10px;background:#f8fafc;color:#64748b;font-size:13px;border-bottom:1px solid #e2e8f0">Year of Passing</td><td style="padding:6px 10px;font-size:14px;border-bottom:1px solid #e2e8f0">{{ v(rec.year_of_passing) }}</td></tr>
    {% if show_spec %}<tr><td style="padding:6px 10px;background:#f8fafc;color:#64748b;font-size:13px;border-bottom:1px solid #e2e8f0">Specialization / Stream</td><td style="padding:6px 10px;font-size:14px;border-bottom:1px solid #e2e8f0">{{ v(rec.specialization) }}</td></tr>{% endif %}
    <tr><td style="padding:6px 10px;background:#f8fafc;color:#64748b;font-size:13px;border-bottom:1px solid #e2e8f0">CGPA / Percentage</td><td style="padding:6px 10px;font-size:14px;border-bottom:1px solid #e2e8f0">{% if rec.cgpa %}CGPA {{ rec.cgpa }}{% elif rec.percentage %}{{ rec.percentage }}%{% else %}—{% endif %}</td></tr>
    {% if rec.course_duration_years %}<tr><td style="padding:6px 10px;background:#f8fafc;color:#64748b;font-size:13px;border-bottom:1px solid #e2e8f0">Duration / Mode</td><td style="padding:6px 10px;font-size:14px;border-bottom:1px solid #e2e8f0">{{ rec.course_duration_years }} yrs · {{ pretty_mode(rec.course_type) }}</td></tr>{% endif %}
    {% if rec.roll_or_registration_no %}<tr><td style="padding:6px 10px;background:#f8fafc;color:#64748b;font-size:13px">Roll / Registration No.</td><td style="padding:6px 10px;font-size:14px">{{ v(rec.roll_or_registration_no) }}</td></tr>{% endif %}
  </table>
  {% else %}
  <p style="color:#94a3b8;font-size:13px;margin:6px 0">Not provided.</p>
  {% endif %}
{% endmacro %}
<!DOCTYPE html>
<html>
<head><meta charset="UTF-8"><title>EasyForm review</title></head>
<body style="margin:0;padding:24px 12px;background:#f1f5f9;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Arial,sans-serif;color:#0f172a">
  <table cellpadding="0" cellspacing="0" border="0" style="max-width:680px;margin:0 auto;width:100%;background:#fff;border-radius:14px;overflow:hidden;box-shadow:0 4px 24px -8px rgba(15,23,42,0.15)">
    <tr><td style="background:linear-gradient(135deg,#4f46e5,#9333ea);padding:24px 28px;color:#fff">
      <h1 style="margin:0;font-size:22px;font-weight:700">EasyForm</h1>
      <p style="margin:6px 0 0;font-size:14px;opacity:0.92">Please review and confirm your application details</p>
    </td></tr>
    <tr><td style="padding:24px 28px">
      <p style="margin:0 0 14px">Hi <strong>{{ candidate_name or "there" }}</strong>,</p>
      <p style="margin:0 0 18px">Great news — we've extracted all the required information from your documents. Please review the details below.</p>
      <div style="background:#eef2ff;border:1px solid #c7d2fe;border-radius:10px;padding:14px 16px;margin:0 0 24px">
        <strong style="color:#3730a3">Reply with "CONFIRM"</strong> if everything is correct (we'll finalise your form). Otherwise reply with your corrections — e.g. <code style="background:#fff;padding:2px 6px;border-radius:4px;font-size:12.5px">caste: OBC</code> or attach a different document.
      </div>

      {# ---------- PERSONAL ---------- #}
      <h2 style="font-size:13px;font-weight:700;color:#4f46e5;letter-spacing:0.06em;text-transform:uppercase;margin:24px 0 8px;border-bottom:2px solid #4f46e5;padding-bottom:6px">Personal Information</h2>
      <table cellpadding="0" cellspacing="0" border="0" style="width:100%;border-collapse:collapse">
        <tr><td style="padding:8px 10px;background:#f8fafc;width:38%;color:#64748b;font-size:13px;border-bottom:1px solid #e2e8f0">Name</td><td style="padding:8px 10px;font-size:14px;border-bottom:1px solid #e2e8f0">{{ v(p.name) }}</td></tr>
        <tr><td style="padding:8px 10px;background:#f8fafc;color:#64748b;font-size:13px;border-bottom:1px solid #e2e8f0">Father's Name</td><td style="padding:8px 10px;font-size:14px;border-bottom:1px solid #e2e8f0">{{ v(p.father_name) }}</td></tr>
        <tr><td style="padding:8px 10px;background:#f8fafc;color:#64748b;font-size:13px;border-bottom:1px solid #e2e8f0">Mother's Name</td><td style="padding:8px 10px;font-size:14px;border-bottom:1px solid #e2e8f0">{{ v(p.mother_name) }}</td></tr>
        <tr><td style="padding:8px 10px;background:#f8fafc;color:#64748b;font-size:13px;border-bottom:1px solid #e2e8f0">Date of Birth</td><td style="padding:8px 10px;font-size:14px;border-bottom:1px solid #e2e8f0">{{ v(p.date_of_birth) }}</td></tr>
        <tr><td style="padding:8px 10px;background:#f8fafc;color:#64748b;font-size:13px;border-bottom:1px solid #e2e8f0">Age</td><td style="padding:8px 10px;font-size:14px;border-bottom:1px solid #e2e8f0">{{ v(p.age) }}</td></tr>
        <tr><td style="padding:8px 10px;background:#f8fafc;color:#64748b;font-size:13px;border-bottom:1px solid #e2e8f0">Gender</td><td style="padding:8px 10px;font-size:14px;border-bottom:1px solid #e2e8f0">{{ v(p.gender) }}</td></tr>
        <tr><td style="padding:8px 10px;background:#f8fafc;color:#64748b;font-size:13px;border-bottom:1px solid #e2e8f0">Marital Status</td><td style="padding:8px 10px;font-size:14px;border-bottom:1px solid #e2e8f0;text-transform:capitalize">{{ v(p.marital_status) }}</td></tr>
        <tr><td style="padding:8px 10px;background:#f8fafc;color:#64748b;font-size:13px;border-bottom:1px solid #e2e8f0">Nationality</td><td style="padding:8px 10px;font-size:14px;border-bottom:1px solid #e2e8f0">{{ v(p.nationality) }}</td></tr>
        <tr><td style="padding:8px 10px;background:#f8fafc;color:#64748b;font-size:13px;border-bottom:1px solid #e2e8f0">Category / Caste</td><td style="padding:8px 10px;font-size:14px;border-bottom:1px solid #e2e8f0">{{ v(p.caste) }}</td></tr>
        <tr><td style="padding:8px 10px;background:#f8fafc;color:#64748b;font-size:13px">Disability Status</td><td style="padding:8px 10px;font-size:14px">{{ v(p.disability_status) }}</td></tr>
      </table>

      {# ---------- CONTACT ---------- #}
      <h2 style="font-size:13px;font-weight:700;color:#4f46e5;letter-spacing:0.06em;text-transform:uppercase;margin:24px 0 8px;border-bottom:2px solid #4f46e5;padding-bottom:6px">Contact</h2>
      <table cellpadding="0" cellspacing="0" border="0" style="width:100%;border-collapse:collapse">
        <tr><td style="padding:8px 10px;background:#f8fafc;width:38%;color:#64748b;font-size:13px;border-bottom:1px solid #e2e8f0">Email</td><td style="padding:8px 10px;font-size:14px;border-bottom:1px solid #e2e8f0">{{ v(p.email) }}</td></tr>
        <tr><td style="padding:8px 10px;background:#f8fafc;color:#64748b;font-size:13px">Mobile Number</td><td style="padding:8px 10px;font-size:14px">{{ v(p.mobile_number) }}</td></tr>
      </table>

      {# ---------- ADDRESS ---------- #}
      <h2 style="font-size:13px;font-weight:700;color:#4f46e5;letter-spacing:0.06em;text-transform:uppercase;margin:24px 0 8px;border-bottom:2px solid #4f46e5;padding-bottom:6px">Address</h2>
      <table cellpadding="0" cellspacing="0" border="0" style="width:100%;border-collapse:collapse">
        <tr><td style="padding:8px 10px;background:#f8fafc;width:38%;color:#64748b;font-size:13px;border-bottom:1px solid #e2e8f0;vertical-align:top">Permanent Address</td><td style="padding:8px 10px;font-size:14px;border-bottom:1px solid #e2e8f0">{{ v(p.permanent_address) }}{% if p.permanent_pin_code %}<br><strong>PIN:</strong> {{ p.permanent_pin_code }}{% endif %}</td></tr>
        <tr><td style="padding:8px 10px;background:#f8fafc;color:#64748b;font-size:13px;vertical-align:top">Correspondence Address</td><td style="padding:8px 10px;font-size:14px">{{ v(p.correspondence_address) }}{% if p.correspondence_pin_code %}<br><strong>PIN:</strong> {{ p.correspondence_pin_code }}{% endif %}</td></tr>
      </table>

      {# ---------- EDUCATION ---------- #}
      <h2 style="font-size:13px;font-weight:700;color:#4f46e5;letter-spacing:0.06em;text-transform:uppercase;margin:24px 0 4px;border-bottom:2px solid #4f46e5;padding-bottom:6px">Education</h2>

      <h3 style="font-size:14px;font-weight:700;color:#334155;margin:14px 0 4px">10th Class</h3>
      {{ edu_table(p.tenth, show_spec=false, show_period=false) }}

      <h3 style="font-size:14px;font-weight:700;color:#334155;margin:18px 0 4px">12th Class</h3>
      {{ edu_table(p.twelfth) }}

      <h3 style="font-size:14px;font-weight:700;color:#334155;margin:18px 0 4px">Graduation</h3>
      {{ edu_table(p.graduation) }}

      {% if p.postgraduation %}
      <h3 style="font-size:14px;font-weight:700;color:#334155;margin:18px 0 4px">Post-Graduation</h3>
      {{ edu_table(p.postgraduation) }}
      {% endif %}

      {# ---------- DOCUMENTS ---------- #}
      <h2 style="font-size:13px;font-weight:700;color:#4f46e5;letter-spacing:0.06em;text-transform:uppercase;margin:24px 0 8px;border-bottom:2px solid #4f46e5;padding-bottom:6px">Documents Received</h2>
      <table cellpadding="0" cellspacing="0" border="0" style="width:100%;border-collapse:collapse">
        <tr><td style="padding:8px 10px;background:#f8fafc;width:38%;color:#64748b;font-size:13px;border-bottom:1px solid #e2e8f0">Aadhaar</td><td style="padding:8px 10px;font-size:14px;border-bottom:1px solid #e2e8f0">{{ present(p.aadhaar_present) }}</td></tr>
        <tr><td style="padding:8px 10px;background:#f8fafc;color:#64748b;font-size:13px;border-bottom:1px solid #e2e8f0">PAN</td><td style="padding:8px 10px;font-size:14px;border-bottom:1px solid #e2e8f0">{{ present(p.pan_present) }}</td></tr>
        <tr><td style="padding:8px 10px;background:#f8fafc;color:#64748b;font-size:13px;border-bottom:1px solid #e2e8f0">Passport Photo</td><td style="padding:8px 10px;font-size:14px;border-bottom:1px solid #e2e8f0">{{ yn(p.passport_photo_valid) }}</td></tr>
        <tr><td style="padding:8px 10px;background:#f8fafc;color:#64748b;font-size:13px">Signature</td><td style="padding:8px 10px;font-size:14px">{{ yn(p.signature_valid) }}</td></tr>
      </table>

      <div style="margin-top:28px;padding:16px 18px;background:#fef3c7;border:1px solid #fcd34d;border-radius:10px;color:#78350f;font-size:14px">
        <strong>Final step:</strong> Reply <strong>"CONFIRM"</strong> to submit, or send your corrections.
      </div>

      <p style="margin-top:24px;font-size:12px;color:#94a3b8">Reference ID: {{ user_id }}</p>
      <p style="margin:4px 0 0;font-size:12px;color:#94a3b8">— EasyForm</p>
    </td></tr>
  </table>
</body>
</html>
