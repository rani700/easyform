# --- Required: OpenAI ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# --- Service ---
LOG_LEVEL=INFO
SQLITE_PATH=/data/easyform.db

# --- Email-driven flow (set MAIL_ENABLED=true to turn it on) ---
MAIL_ENABLED=false

# Gmail IMAP/SMTP example. With Gmail you need an App Password
# (myaccount.google.com/apppasswords; requires 2FA). The same App Password
# works for both IMAP and SMTP.
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=your.easyform.address@gmail.com
IMAP_PASSWORD=your-16-char-app-password

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your.easyform.address@gmail.com
SMTP_PASSWORD=your-16-char-app-password
MAIL_FROM=your.easyform.address@gmail.com

# Cadence
POLL_INTERVAL_SECONDS=120          # how often to check the inbox
SCHEDULER_INTERVAL_SECONDS=1800    # how often the retry scan runs (30 min)
RETRY_INTERVAL_HOURS=6             # gap between follow-up emails
